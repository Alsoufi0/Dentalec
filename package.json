{
  "name": "simav-dental-tutor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node scripts/prepare-server.mjs && node --watch server/index.js",
    "prebuild": "node scripts/prepare-build.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node scripts/prepare-server.mjs && node server/index.js",
    "start:prod": "npm run build && npm start"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "openai": "^6.7.0",
    "vite": "^7.1.12",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {}
}
